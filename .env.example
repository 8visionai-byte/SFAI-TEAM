# === TRYB BEZPIECZNY (zalecany do publicznego uzycia) ===
# Adres proxy (Supabase Edge Function agent-chat). Gdy ustawiony, aplikacja
# wola model przez serwer, a klucz API zostaje na serwerze (nie trafia do przegladarki).
# Przyklad: https://<TWOJ_REF>.supabase.co/functions/v1/agent-chat
VITE_AGENT_API_URL=

# === TRYB TESTOWY (tylko wewnetrzne testy, np. na Lovable) ===
# Klucz API Anthropic uzywany bezposrednio w przegladarce. Uzywaj tylko gdy
# NIE ustawiono VITE_AGENT_API_URL. Bez obu aplikacja dziala w trybie demo (MOCK).
# W Lovable dodaj go jako sekret projektu o tej samej nazwie.
VITE_ANTHROPIC_API_KEY=

# Model Claude (opcjonalnie). Domyslnie claude-sonnet-4-6.
VITE_ANTHROPIC_MODEL=claude-sonnet-4-6
